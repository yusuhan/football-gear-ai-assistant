# Runtime
APP_ENV=local
DATABASE_PATH=data/football_gear.db
# Production PostgreSQL URL. When set, it takes precedence over DATABASE_PATH.
DATABASE_URL=
# Multiple origins can be separated with commas.
BACKEND_CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Operations accounts. Replace both passwords before deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-admin-change-me
SUPPORT_USERNAME=support
SUPPORT_PASSWORD=local-support-change-me
OPERATIONS_SESSION_HOURS=8

# Optional OpenAI mode
USE_OPENAI=false
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
